{
  "listen": "0.0.0.0:8787",
  "refresh_seconds": 60,
  "refresh_timeout_seconds": 90,
  "cache_path": "validatorclock_cache.json",
  "tycho_map_nodes_path": ".local_maps/tycho_nodes.json",
  "map_nodes_paths": {
    "everscale": ".local_maps/everscale_nodes.json",
    "ton": ".local_maps/ton_nodes.json"
  },
  "node_locations": {
    "enabled": true,
    "refresh_seconds": 300,
    "startup_delay_seconds": 3,
    "geo_cache_path": ".local_maps/geo_cache.json",
    "geo_cache_ttl_seconds": 604800,
    "ipinfo_token_env": "IPINFO_TOKEN",
    "ipinfo_lite_base_url": "https://api.ipinfo.io/lite",
    "manual_review_dir": ".local_maps/manual_review",
    "manual_resolved_dir": ".local_maps/manual_resolved",
    "chains": {
      "everscale": {
        "enabled": true,
        "input_path": ".local_maps/raw/everscale_peer_ips.json",
        "output_path": ".local_maps/everscale_nodes.json"
      },
      "tycho-testnet": {
        "enabled": true,
        "input_path": ".local_maps/raw/tycho_peer_ips.json",
        "output_path": ".local_maps/tycho_nodes.json"
      },
      "ton": {
        "enabled": true,
        "input_path": ".local_maps/raw/ton_peer_ips.json",
        "output_path": ".local_maps/ton_nodes.json"
      }
    }
  },
  "chains": [
    {
      "id": "everscale",
      "name": "Everscale",
      "rpc": "https://jrpc.everwallet.net",
      "color": "#6347F5",
      "token_symbol": "EVER",
      "rpc_label": "jrpc.everwallet.net"
    },
    {
      "id": "tycho-testnet",
      "name": "Tycho Testnet",
      "rpc": "https://rpc-testnet.tychoprotocol.com",
      "color": "#2ECC71",
      "token_symbol": "TYCHO",
      "rpc_label": "rpc-testnet.tychoprotocol.com"
    },
    {
      "id": "ton",
      "name": "TON",
      "rpc": "https://toncenter.com/api/v2/jsonRPC",
      "rpc_fallbacks": [
        "https://jrpc-ton.broxus.com"
      ],
      "color": "#4DB8FF",
      "token_symbol": "TON",
      "rpc_label": "toncenter.com + jrpc-ton.broxus.com"
    }
  ]
}
